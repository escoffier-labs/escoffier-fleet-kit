    "repo": "escoffier-labs/agentpantry",
    "version": {
      "source": "gh-release"
    }
  },
  "graphtrail-site": {
    "repo": "escoffier-labs/graphtrail",
    "version": {
      "source": "manual"
    }
  },
  "miseledger-site": {
    "repo": "escoffier-labs/miseledger",
    "version": {
      "source": "gh-release"
    }
  },
  "memory-doctor-site": {
    "repo": "escoffier-labs/memory-doctor",
    "version": {
      "source": "gh-release"
    }
  },
  "bootstrap-doctor-site": {
    "repo": "escoffier-labs/bootstrap-doctor",
    "version": {
      "source": "gh-release"
    }
  },
  "agent-notify-site": {
    "repo": "escoffier-labs/agent-notify",
    "version": {
      "source": "gh-release"
    }
  },
  "cloche-site": {
    "repo": "escoffier-labs/cloche",
    "version": {
      "source": "gh-release"
    }
  },
  "skillet-site": {
